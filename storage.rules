rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function hasActiveSession() {
      return request.auth != null
        && request.auth.token.sessionId is string
        && firestore.exists(/databases/(default)/documents/session_controls/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/session_controls/$(request.auth.uid)).data.activeSessionId == request.auth.token.sessionId;
    }

    // No access by default
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ── Chat images ────────────────────────────────────────────────────────
    // Path: chats/{chatId}/{uploaderId}/{fileName}
    // chatId = "userId1_userId2" (sorted). Uploads are owner-scoped and
    // immutable; participants can read, only the uploader can create.
    match /chats/{chatId}/{uploaderId}/{fileName} {
      allow read: if hasActiveSession()
        && request.auth.uid in chatId.split('_');

      allow write: if hasActiveSession()
        && request.auth.uid in chatId.split('_')
        && request.auth.uid == uploaderId
        && resource == null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ── Avatars ────────────────────────────────────────────────────────────
    // Path: avatars/{userId}/{filename}
    // Owner can write, anyone authenticated can read.
    match /avatars/{userId}/{fileName} {
      allow read: if hasActiveSession();

      allow write: if hasActiveSession()
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
